{
  "name": "@xinyuan0801/d-connect",
  "version": "0.3.5",
  "type": "module",
  "description": "Bridge local coding agents to DingTalk and Feishu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xinyuan0801/d-connect.git"
  },
  "homepage": "https://github.com/xinyuan0801/d-connect#readme",
  "bugs": {
    "url": "https://github.com/xinyuan0801/d-connect/issues"
  },
  "keywords": [
    "agent",
    "cli",
    "daemon",
    "cron",
    "dingtalk",
    "feishu"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "d-connect": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && vite build && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "publish": "pnpm run prepublishOnly && sh -c 'if [ \"${1-}\" = \"--\" ]; then shift; fi; pnpm publish --ignore-scripts \"$@\"' --",
    "prepublishOnly": "pnpm test && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "commander": "^14.0.1",
    "dingtalk-stream": "^2.1.4",
    "ink": "^6.8.0",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
